# 複製為 .env 並填入實際值，.env 不可提交進 git

# PostgreSQL
POSTGRES_DB=oclock
POSTGRES_USER=postgres
DB_PASSWORD=

# 後端 JWT 簽章金鑰
JWT_SECRET=

# 允許呼叫後端 API 的來源（逗號分隔多個），例如 http://<Elastic-IP>
CORS_ALLOWED_ORIGINS=http://localhost:5173

# 前端建置時要呼叫的後端 base URL，部署到 EC2 時填 http://<Elastic-IP>
VITE_API_BASE_URL=http://localhost:8080
