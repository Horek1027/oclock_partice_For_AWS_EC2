<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.oclock.checkin.attendance.mapper.TimeRecordMapper">

    <resultMap id="TimeRecordResultMap" type="com.oclock.checkin.attendance.entity.TimeRecord">
        <id property="id" column="id"/>
        <result property="memberId" column="member_id"/>
        <result property="workDate" column="work_date"/>
        <result property="clockInTime" column="clock_in_time"/>
        <result property="clockOutTime" column="clock_out_time"/>
        <result property="status" column="status"/>
        <result property="remark" column="remark"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <select id="selectByMemberAndDateRange" resultMap="TimeRecordResultMap">
        SELECT *
        FROM time_record
        <where>
            member_id = #{memberId}
            <if test="startDate != null">
                AND work_date &gt;= #{startDate}
            </if>
            <if test="endDate != null">
                AND work_date &lt;= #{endDate}
            </if>
        </where>
        ORDER BY work_date DESC
    </select>

</mapper>
